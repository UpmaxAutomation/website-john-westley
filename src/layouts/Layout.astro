---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = "Fix the structural leaks in your revenue journey. John Westley helps B2B companies find where revenue gets stuck, lost, or missed — then redesigns the right parts in the right order.",
  ogImage = "/og-image.png",
  type = "website"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://growththatholds.com");
const fullTitle = title === "Revenue Journey Redesign" ? "Growth That Holds | Revenue Journey Redesign" : `${title} | Growth That Holds`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://growththatholds.com/#organization",
      "name": "Growth That Holds",
      "url": "https://growththatholds.com",
      "description": "B2B revenue consulting. Structural diagnosis and redesign for companies between $3M and $50M.",
      "founder": { "@id": "https://growththatholds.com/#person" },
      "sameAs": []
    },
    {
      "@type": "Person",
      "@id": "https://growththatholds.com/#person",
      "name": "John Westley",
      "jobTitle": "Founder, Revenue Strategist",
      "worksFor": { "@id": "https://growththatholds.com/#organization" },
      "url": "https://growththatholds.com/about",
      "knowsAbout": ["Revenue Operations", "B2B Sales", "Go-to-Market Strategy", "Customer Success", "Revenue Growth"]
    },
    {
      "@type": "WebSite",
      "@id": "https://growththatholds.com/#website",
      "url": "https://growththatholds.com",
      "name": "Growth That Holds",
      "publisher": { "@id": "https://growththatholds.com/#organization" }
    }
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#090e1a" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- OG / Social -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Growth That Holds" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
    <script>
      // Nav scroll behavior — adds glass blur when not at top
      const nav = document.getElementById('site-nav');
      if (nav) {
        window.addEventListener('scroll', () => {
          nav.classList.toggle('nav-scrolled', window.scrollY > 20);
        }, { passive: true });
      }

      // Metrics counter animation
      const counters = document.querySelectorAll('[data-counter]');
      if (counters.length > 0) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-count');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.3 });
        counters.forEach(el => observer.observe(el));
      }

      // Scroll-reveal for individual elements and groups
      const allReveal = document.querySelectorAll('[data-reveal], [data-reveal-group]');
      if (allReveal.length > 0) {
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = parseInt(el.dataset.revealDelay || '0');
              setTimeout(() => el.classList.add('revealed'), delay);
              revealObserver.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -48px 0px' });
        allReveal.forEach(el => revealObserver.observe(el));
      }
    </script>
  </body>
</html>
