---
const links = [
  { href: "/the-problem", label: "The Problem" },
  { href: "/the-process", label: "How We Fix It" },
  { href: "/where-ai-fits", label: "Where AI Fits" },
  { href: "/about", label: "About John" },
  { href: "/book", label: "Book a Conversation" },
];
---

<footer class="bg-[#090e1a] text-white/60">

  <!-- Pre-footer quote strip -->
  <div class="border-b border-white/[0.06]">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 sm:py-14 flex flex-col gap-6 md:flex-row md:items-center md:justify-between md:gap-8">
      <blockquote class="text-[18px] sm:text-[20px] md:text-[24px] font-semibold tracking-[-0.02em] text-white leading-[1.2] max-w-2xl">
        "The structural taxes aren't rounding errors.<br class="hidden md:block" /> They're why the number doesn't move."
      </blockquote>
      <a
        href="/book"
        class="flex-shrink-0 w-full sm:w-auto inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-white text-[#171717] text-[14px] font-medium rounded-[6px] hover:bg-white/90 transition-colors"
      >
        Book a Conversation
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between md:gap-12">
      <!-- Brand -->
      <div class="max-w-xs">
        <p class="text-white text-[15px] font-semibold tracking-tight mb-3">Growth That Holds</p>
        <p class="text-[14px] leading-relaxed">
          Revenue journey redesign for companies where too much revenue is getting stuck, lost, or missed.
        </p>
      </div>

      <!-- Nav -->
      <nav class="flex flex-col gap-3">
        {links.map(link => (
          <a
            href={link.href}
            class="text-[14px] hover:text-white transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Contact -->
      <div class="flex flex-col gap-3">
        <p class="text-white text-[13px] font-medium uppercase tracking-widest">Contact</p>
        <a href="mailto:john@growththatholds.com" class="text-[14px] hover:text-white transition-colors">
          john@growththatholds.com
        </a>
        <p class="text-[13px] mt-2">
          Questions before booking?<br />
          If we are not a fit, I will tell you quickly.
        </p>
      </div>
    </div>

    <div class="mt-12 sm:mt-16 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between gap-3 sm:gap-4">
      <p class="text-[13px]">© {new Date().getFullYear()} Growth That Holds. All rights reserved.</p>
      <p class="text-[13px]">Revenue Journey Redesign</p>
    </div>
  </div>
</footer>
