---
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
const currentPath = Astro.url.pathname;

const links = [
  { href: "/the-problem", label: "The Problem" },
  { href: "/the-process", label: "How We Fix It" },
  { href: "/where-ai-fits", label: "Where AI Fits" },
  { href: "/about", label: "About John" },
];
---

<nav
  id="site-nav"
  class:list={[
    "fixed top-0 left-0 right-0 z-50 transition-all duration-300",
    dark ? "bg-transparent" : "bg-white/90 backdrop-blur-md",
  ]}
  style={dark ? "" : "box-shadow: rgba(0,0,0,0.06) 0px 1px 0px;"}
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class:list={[
        "text-[15px] font-semibold tracking-tight transition-opacity hover:opacity-70",
        dark ? "text-white" : "text-[#171717]",
      ]}
    >
      Growth That Holds
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            "relative text-[14px] font-medium transition-opacity hover:opacity-60",
            currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
              ? dark ? "text-white" : "text-[#171717]"
              : dark ? "text-white/60" : "text-[#4d4d4d]",
          ]}
        >
          {link.label}
          {(currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) && (
            <span
              class:list={[
                "absolute -bottom-[22px] left-1/2 -translate-x-1/2 w-1 h-1 rounded-full",
                dark ? "bg-white/40" : "bg-[#2563eb]",
              ]}
            ></span>
          )}
        </a>
      ))}
    </div>

    <!-- CTA -->
    <a
      href="/book"
      class:list={[
        "hidden md:inline-flex items-center gap-1.5 px-4 py-2 text-[13px] font-medium rounded-[6px] transition-all",
        dark
          ? "bg-white text-[#171717] hover:bg-white/90"
          : "bg-[#171717] text-white hover:bg-[#2a2a2a]",
      ]}
    >
      Book a Conversation
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class:list={[
        "md:hidden p-2 rounded-md transition-colors",
        dark ? "text-white hover:bg-white/10" : "text-[#171717] hover:bg-black/5",
      ]}
      aria-label="Toggle menu"
    >
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
        <rect x="2" y="4" width="14" height="1.5" rx="0.75" fill="currentColor"/>
        <rect x="2" y="8.25" width="14" height="1.5" rx="0.75" fill="currentColor"/>
        <rect x="2" y="12.5" width="14" height="1.5" rx="0.75" fill="currentColor"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-black/8 bg-white"
  >
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-4">
      {links.map(link => (
        <a href={link.href} class="text-[15px] font-medium text-[#171717] hover:text-[#2563eb] transition-colors">
          {link.label}
        </a>
      ))}
      <a
        href="/book"
        class="inline-flex items-center justify-center px-4 py-2.5 text-[14px] font-medium bg-[#171717] text-white rounded-[6px] hover:bg-[#2a2a2a] transition-colors"
      >
        Book a Conversation
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
